# Only matters when this folder ends up nested under a web-servable path
# (e.g. subfolder hosting where everything lives under one directory instead
# of a separate docroot). Blocks direct HTTP access; PHP's own require/include
# calls read files at the filesystem level and are unaffected by this.
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
